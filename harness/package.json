{
  "name": "forwardeval-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic coding-evaluation harness: runs Claude against deterministic coding tasks, captures transcripts, classifies failures, measures token ROI.",
  "bin": {
    "forwardeval": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "eval": "tsx src/index.ts run",
    "sanity": "tsx src/sanity.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
